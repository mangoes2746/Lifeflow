rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Private user data: only the owner can read/write ──
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Public game profiles: any signed-in user can read, only owner can write ──
    match /gameProfiles/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Friend requests: sender creates, sender/recipient can read/update/delete ──
    match /friendRequests/{requestId} {
      allow create: if request.auth != null
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid;
      allow read, update, delete: if request.auth != null
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
    }

    // ── Friend links: either member can create or update ──
    match /friendships/{pairKey} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.members;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
      allow update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }

    // ── Private conversations and messages ──
    match /conversations/{pairKey} {
      // Either member can create or update the conversation doc
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.members;
      allow read, update, delete: if request.auth != null
        && request.auth.uid in resource.data.members;

      match /messages/{messageId} {
        // Allow create if the user is the sender AND is a member of the conversation
        // Use exists() check so it works even if conversation was just created
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.senderUid
          && (
            // Conversation already exists and user is a member
            (exists(/databases/$(database)/documents/conversations/$(pairKey))
              && request.auth.uid in get(/databases/$(database)/documents/conversations/$(pairKey)).data.members)
            // Or conversation was just created in the same batch (members in request)
            || request.auth.uid in request.resource.data.get('members', [])
          );
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/conversations/$(pairKey))
          && request.auth.uid in get(/databases/$(database)/documents/conversations/$(pairKey)).data.members;
      }
    }

    // ── Blocks: blocker controls the relation ──
    match /blocks/{blockId} {
      allow create, update: if request.auth != null
        && request.resource.data.blockerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.blockerUid == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.blockerUid == request.auth.uid
            || resource.data.blockedUid == request.auth.uid);
    }

  }
}
